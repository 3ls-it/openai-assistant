    async def action_quit(self) -> None:
        """
        Action to display the quit dialogue, then perform
        server-side cleanup and exit app.
        """

        async def _check_quit(quit: bool | None) -> None:
            if quit:
                try:
                    self.notify(
                        "Attempting to delete server-side artifacts.",
