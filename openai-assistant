    async def continue_chat(self, chpath: str) -> None:
        """
        Run the ContinuationDialogue and get further instructions
        if any. Call actual continuation
        """

        ## calback function
        def _on_done(fut: asyncio.Future):
            try:
                further = fut.result()
            except Exception as e:
                self.api.logger.debug(f"in continue_chat()._on_done()\n{e}")

            if further is not None:
                asyncio.create_task(self._run_continue(chpath, further))
        ##

        loop = asyncio.get_running_loop()
        self._instruction_future = loop.create_future()
        self.push_screen(ContinuationDialogue())
        self._instruction_future.add_done_callback(_on_done)
    # End continue_chat()


    async def _run_continue(self, chpath: str, further: str) -> None: 
        """
        Here we construct a continuation prompt, re-open the chat file
        and send the continuation prompt to the API.
        """

        # Continuation instructions
        inst = """
        We are continuing an existing chat. This is the relevant chat log. 
        Prompt the user for the following actions:
        1) Continue directly with no summary,
        2) Provide a brief summary and continue,
        3) Provide a detailed summary and await further user input.
        """

        chname = os.path.basename(chpath)
        self.input_area.load_text("Thinking...")
        await self.show_status(f"Loading chat: {chname}")
         
        # Read chat file
        with open(chpath, 'r', encoding="utf-8") as f:
            chat_history = f.read()

        # Concat instructions, chat log and further instructions
        prompt = f"{inst}\n\nChat log:\n{chat_history}"
        if further.strip():
            prompt += f"\n\nFurther instructions:\n{further}"

        # Explicitly end conversation
        self.api.end_conversation()

        # Close existing log file
        self.lf.flush()
        self.lf.close()
        # Re-open selected chat
        now = datetime.now()
        tstamp = now.strftime('%-d %B %Y %-I:%M%p')
        self.lf = open(chpath, "a", encoding="utf-8")
        self.lf.write(f"\nContinuing session at: {tstamp}\n\n")
        self.lf.write(f"[further instructions] {further}\n\n")
        self.lf.flush()
        # Clear main chat window
        await self.chat_view.remove_children()
        self.startup_screen = False
        # Display further instructions
        if further.strip():
            await self.chat_view.mount(
                DisplayPrompt(further, border_title="Further Instructions")
            )

        # Send prompt and await response
        start = time.time()
        result = await asyncio.to_thread(
            self.api.send_query,
            prompt,
            self.lf,
            self.images_dir,
            self.artifacts_dir,
        )
        elapsed = time.time() - start

        has_text = bool(result.text and result.text.strip())
        if has_text:
            try:
                if self.lf:
                    self.lf.write("\n[assistant] " + result.text + "\n\n")
                    self.lf.flush()
            except Exception as e:
                self.notify(
                    f"[red]Error writing AI response to log: {e}",
                    title="Error Saving File!",
                    severity="error",
                    timeout=5,
                )

            if "API Error" in result.text:
                await self.chat_view.mount(
                    DisplayNotifications(result.text, border_title=self.assistant_name)
                )
            else:
                await self.chat_view.mount(
                    DisplayResponse(result.text, border_title=self.assistant_name)
                )

        if result.image_paths or result.artifact_paths:
            note = self._format_generated_files_notification(
                result.image_paths,
                result.artifact_paths,
            )
            await self.chat_view.mount(
                DisplayNotifications(note, border_title="Notification")
            )

        # Clear input box
        self.input_area.clear()
        await self.show_status(f"Run completed in {elapsed:.2f}s")
    # End _run_continue()


    async def action_new_chat(self) -> None:
