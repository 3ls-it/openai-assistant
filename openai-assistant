        yield Grid(
            Label(msg, id="message"),
            self.dismiss_button,
            id="upload_result",
        ) 

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "dismiss":
            self.app.pop_screen()
