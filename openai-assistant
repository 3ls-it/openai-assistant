class CleanupJournal:
    """
    Append-only JSONL journal for crash-safe server-side cleanup replay.
    """

    def __init__(self, path: Path, logger=None) -> None:
        self.path = path
        self.logger = logger
        self.path.parent.mkdir(parents=True, exist_ok=True)

    def append(self, event: dict, *, fsync: bool = False) -> None:
        """
        Append one JSON object as a single JSONL record.
        Never raise into caller.
        """
        try:
            record = dict(event)
            record.setdefault("ts", time.time())

            with open(self.path, "a", encoding="utf-8") as f:
                f.write(json.dumps(record, ensure_ascii=False) + "\n")
                f.flush()
                if fsync:
                    os.fsync(f.fileno())

        except Exception as e:
            if self.logger:
                try:
                    self.logger.error(f"CleanupJournal append failed: {e}")
                except Exception:
                    pass

    def iter_events(self):
        """
        Yield parsed JSONL records. Ignore malformed/partial lines.
        """
        if not self.path.exists():
            return

        try:
            with open(self.path, "r", encoding="utf-8") as f:
                for line in f:
                    line = line.strip()
                    if not line:
                        continue
                    try:
                        yield json.loads(line)
                    except Exception:
                        continue
        except Exception as e:
            if self.logger:
                try:
                    self.logger.error(f"CleanupJournal read failed: {e}")
                except Exception:
                    pass
            return
