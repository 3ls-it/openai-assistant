class Openai_API():
    """
    Encapsulates an OpenAI client instance.
    """
    def __init__(self, config, logger=None, journal_path=None) -> None:
        self.config = config
        self.api_key = self.config["OPENAI_API_KEY"]
        self.gpt_model = self.config["MODEL"]
        self.developer_msg = self.config["DEVELOPER_MSG"]
        self.vector_store_id = self.config["VECTOR_STORE_ID"]
        delete_flag = self.config["DELETE_SERVER_SIDE"].strip().lower()
        if delete_flag == 'true' or delete_flag == 'yes':
            self.delete_flag = True
        else:
            self.delete_flag = False

        self.client = OpenAI(api_key=self.api_key)
        self.logger = logger or logging.getLogger("openai_assistant.api")
        self.journal = CleanupJournal(
            Path(journal_path) if journal_path else Path.home() / ".openai-assistant" / "server_cleanup.jsonl",
            logger=self.logger
        )
        self.response_id = None
        self.session_resp_ids = []

        # Locks
        self._conversation_lock = threading.Lock()
        self._inflight_lock = threading.Lock() # serialize requests per API instance

        # server-side conversation object backing this chat session
        conv = self.client.conversations.create(metadata={"app": "openai-assistant"})
        self.conversation_id = conv.id
        self.logger.info("Created conversation %s", self.conversation_id)
        self._journal_conversation_created(self.conversation_id)

        self.vector_store = None
        if self.vector_store_id:
            self.vector_store = self.client.vector_stores.retrieve(
                vector_store_id=self.vector_store_id
            )
            self.logger.info("vector_store retrieved id=%s", self.vector_store.id)
    # End constructor


    def _build_prompt(self, msg) -> list:
        return [
            {"role": "system",
             "content": self.developer_msg},
            {"role": "user",
             "content": msg},
        ]


    def _journal_conversation_created(self, conv_id: str) -> None:
        """
        Record creation of a server-side conversation in the cleanup journal.
        """
        if not conv_id:
            return

        self.journal.append({
            "event": "conversation_created",
            "conv_id": conv_id,
        })


    def _journal_response_created(self, conv_id: str, resp_id: str) -> None:
        """
        Record creation of a server-side response in the cleanup journal.
        """
        if not conv_id or not resp_id:
            return

        self.journal.append({
            "event": "response_created",
            "conv_id": conv_id,
            "resp_id": resp_id,
        })


    def _ensure_conversation(self) -> None:
        """
        Create/ensure a Conversation object.
        Invariant: after return, self.conversation_id is not None.
        """
        with self._conversation_lock:
            if self.conversation_id is not None:
                return

            conv = self.client.conversations.create(
                metadata={"app": "openai-assistant"}
            )

            conv_id = getattr(conv, "id", None)
            if not conv_id:
                # Extremely unexpected; fail fast so we don't run with a broken state
                raise RuntimeError("conversations.create() returned no conversation id")

            self.conversation_id = conv_id
            self.logger.info("Created new conversation %s", self.conversation_id)
            self._journal_conversation_created(self.conversation_id)


    def _safe_model_dump(self, obj):
        """
        Best-effort structured dump for debug logging.
        Redacts or truncates very large fields so api.log stays readable.
        """
        try:
            if hasattr(obj, "model_dump"):
                data = obj.model_dump()
            elif isinstance(obj, dict):
                data = obj
            else:
                return repr(obj)
        except Exception as e:
            try:
                self.logger.debug(f"in _safe_model_dump()\n{e}")
            except Exception:
                pass
            return repr(obj)

        def scrub(x):
            if isinstance(x, dict):
                out = {}
                for k, v in x.items():
                    if k in {"result", "b64_json"} and isinstance(v, str):
                        if len(v) > 200:
                            out[k] = f"<redacted_large_field len={len(v)}>"
                        else:
                            out[k] = v
                    elif k in {"content", "text"} and isinstance(v, str):
                        if len(v) > 1000:
                            out[k] = v[:1000] + "...<truncated>"
                        else:
                            out[k] = v
                    else:
                        out[k] = scrub(v)
                return out
            elif isinstance(x, list):
                return [scrub(i) for i in x]
            else:
                return x

        return scrub(data)


    def _log_response_output(self, resp) -> None:
        """
        Debug-log response output items, especially tool calls.
        """
        try:
            output = getattr(resp, "output", []) or []
            output_text = getattr(resp, "output_text", "") or ""
            resp_id = getattr(resp, "id", None)

            tool_item_count = 0
            for item in output:
                item_type = getattr(item, "type", None) or ""
                if item_type != "message":
                    tool_item_count += 1

            self.logger.debug(
                "Response summary: resp.id=%r output_text_len=%d output_items=%d tool_items=%d",
                resp_id,
                len(output_text),
                len(output),
                tool_item_count,
            )

        except Exception as e:
            try:
                self.logger.debug(f"in _log_response_output() summary\n{e}")
            except Exception:
                pass

        for i, item in enumerate(getattr(resp, "output", []) or []):
            try:
                item_type = getattr(item, "type", None)
                item_id = getattr(item, "id", None)
                item_status = getattr(item, "status", None)
                item_role = getattr(item, "role", None)

                self.logger.debug(
                    "resp.output[%d]: type=%r id=%r status=%r role=%r",
                    i, item_type, item_id, item_status, item_role
                )

                if item_type == "message":
                    try:
                        content = getattr(item, "content", []) or []
                        self.logger.debug(
                            "resp.output[%d] message content_items=%d",
                            i, len(content)
                        )
                    except Exception as e:
                        try:
                            self.logger.debug(f"in _log_response_output() message branch\n{e}")
                        except Exception:
                            pass

                elif item_type == "image_generation_call":
                    try:
                        result = getattr(item, "result", None)
                        result_len = len(result) if isinstance(result, str) else None
                        self.logger.debug(
                            "Tool call: image_generation id=%r status=%r result_len=%r",
                            item_id, item_status, result_len
                        )
                    except Exception as e:
                        try:
                            self.logger.debug(f"in _log_response_output() image_generation_call branch\n{e}")
                        except Exception:
                            pass

                else:
                    # Generic handler for code_interpreter, file_search, web_search, and any future tool item types
                    self.logger.debug(
                        "Non-message output item detail[%d]=%r",
                        i, self._safe_model_dump(item)
                    )

            except Exception as e:
                try:
                    self.logger.debug(f"in _log_response_output() item loop\n{e}")
                except Exception:
                    pass


    def _write_bytes_to_file(self, data: bytes, out_dir: str, filename: str) -> str | None:
        """
        Write bytes to a file in out_dir and return the saved path.
        Returns None on failure.
        """
        try:
            if not out_dir:
                raise ValueError("out_dir must be specified")

            os.makedirs(out_dir, exist_ok=True)
            out_path = os.path.join(out_dir, filename)

            with open(out_path, "wb") as f:
                f.write(data)

            return out_path

        except Exception as e:
            try:
                self.logger.error(f"in _write_bytes_to_file() saving {filename}: {e}")
            except Exception:
                pass
            return None


    def _extract_and_save_images(self, resp, images_dir: str | None) -> list[str]:
        """
        Extract image_generation_call items from resp.output, save them
        to images_dir, and return list of saved image paths.
        """
        image_paths = []

        if images_dir is None:
            return image_paths

        try:
            os.makedirs(images_dir, exist_ok=True)
        except Exception as e:
            try:
                self.logger.error(f"in _extract_and_save_images() mkdir failed: {e}")
            except Exception:
                pass
            return image_paths

        for item in getattr(resp, "output", []) or []:
            try:
                item_type = getattr(item, "type", None)
                if item_type != "image_generation_call":
                    continue

                image_base64 = getattr(item, "result", None)
                if not image_base64:
                    try:
                        self.logger.debug("image_generation_call had no result payload")
                    except Exception:
                        pass
                    continue

                now = datetime.now()
                image_fname = f"image_{now:%Y%m%d_%H%M%S_%f}.png"

                image_bytes = base64.b64decode(image_base64)
                saved = self._write_bytes_to_file(image_bytes, images_dir, image_fname)
                if saved:
                    image_paths.append(saved)
                    try:
                        self.logger.info(f"Saved generated image {saved}")
                    except Exception:
                        pass

            except Exception as e:
                try:
                    self.logger.error(f"in _extract_and_save_images(): {e}")
                except Exception:
                    pass

        return image_paths
    # End _extract_and_save_images()


    def _extract_container_file_citations(self, resp) -> list[dict]:
        """
        Inspect assistant message annotations for container_file_citation
        entries and return a list of dicts:
            {
                "container_id": ...,
                "file_id": ...,
                "filename": ...
            }
        """
        citations = []

        def _get(obj, key, default=None):
            if isinstance(obj, dict):
                return obj.get(key, default)
            return getattr(obj, key, default)

        for item in getattr(resp, "output", []) or []:
            try:
                if _get(item, "type") != "message":
                    continue

                for content_item in _get(item, "content", []) or []:
                    annotations = _get(content_item, "annotations", []) or []

                    for ann in annotations:
                        ann_type = _get(ann, "type")
                        if ann_type != "container_file_citation":
                            continue

                        citation = {
                            "container_id": _get(ann, "container_id"),
                            "file_id": _get(ann, "file_id"),
                            "filename": _get(ann, "filename"),
                        }
                        citations.append(citation)

                        try:
                            self.logger.debug(
                                "Found container_file_citation container_id=%r file_id=%r filename=%r",
                                citation["container_id"],
                                citation["file_id"],
                                citation["filename"],
                            )
                        except Exception:
                            pass

            except Exception as e:
                try:
                    self.logger.debug(f"in _extract_container_file_citations()\n{e}")
                except Exception:
                    pass

        return citations


    def _download_container_file(
        self,
        container_id: str,
        file_id: str,
        filename: str,
        artifacts_dir: str | None
    ) -> str | None:
        """
        Download one generated code-interpreter/container file and save it
        to artifacts_dir. Returns saved path or None on failure.
        """
        if not artifacts_dir:
            return None

        if not container_id or not file_id:
            try:
                self.logger.debug(
                    "Skipping container file download: container_id=%r file_id=%r",
                    container_id, file_id
                )
            except Exception:
                pass
            return None

        try:
            os.makedirs(artifacts_dir, exist_ok=True)
        except Exception as e:
            try:
                self.logger.error(f"in _download_container_file() mkdir failed: {e}")
            except Exception:
                pass
            return None

        try:
            file_bytes = self.client.containers.files.content.retrieve(
                file_id=file_id,
                container_id=container_id,
            )

            # Some SDKs may return a response-like object rather than bare bytes.
            if hasattr(file_bytes, "read"):
                data = file_bytes.read()
            else:
                data = file_bytes

            if not isinstance(data, (bytes, bytearray)):
                raise TypeError(f"Expected bytes-like object, got {type(data)}")

            safe_name = filename or f"{file_id}.bin"
            saved = self._write_bytes_to_file(bytes(data), artifacts_dir, safe_name)

            if saved:
                try:
                    self.logger.info(
                        "Downloaded container artifact container_id=%s file_id=%s path=%s",
                        container_id, file_id, saved
                    )
                except Exception:
                    pass

            return saved

        except Exception as e:
            try:
                self.logger.error(
                    f"in _download_container_file() container_id={container_id} file_id={file_id}: {e}"
                )
            except Exception:
                pass
            return None
    # End _download_container_file()


    def _download_container_artifacts(self, resp, artifacts_dir: str | None) -> list[str]:
        """
        Find container_file_citation annotations in the response and
        download all referenced files into artifacts_dir.
        """
        artifact_paths = []

        citations = self._extract_container_file_citations(resp)
        if not citations:
            return artifact_paths

        for citation in citations:
            try:
                container_id = citation.get("container_id")
                file_id = citation.get("file_id")
                filename = citation.get("filename")

                saved = self._download_container_file(
                    container_id=container_id,
                    file_id=file_id,
                    filename=filename,
                    artifacts_dir=artifacts_dir,
                )
                if saved:
                    artifact_paths.append(saved)

            except Exception as e:
                try:
                    self.logger.error(f"in _download_container_artifacts(): {e}")
                except Exception:
                    pass

        return artifact_paths
    # End _download_container_artifacts()


    # Server-clean-up journal helpers
    def _journal_cleanup_requested(self, conv_id: str) -> None:
        """
        Record that cleanup has been requested for a conversation.
        """
        if not conv_id:
            return

        self.journal.append({
            "event": "cleanup_requested",
            "conv_id": conv_id,
        }, fsync=True)


    def _journal_cleanup_succeeded(self, conv_id: str) -> None:
        """
        Record that cleanup completed successfully for a conversation.
        """
        if not conv_id:
            return

        self.journal.append({
            "event": "cleanup_succeeded",
            "conv_id": conv_id,
        }, fsync=True)


    def _journal_cleanup_failed(self, conv_id: str, err: str) -> None:
        """
        Record that cleanup failed for a conversation.
        """
        if not conv_id:
            return

        self.journal.append({
            "event": "cleanup_failed",
            "conv_id": conv_id,
            "err": err,
        }, fsync=True)


    def _delete_resp_from_list(self, resp_list: list[str]) -> list[str]:
        """
        Delete response objects from server.

        Returns a list of response IDs successfully handled.
        'Not found' is treated as success-equivalent/idempotent.
        Raises on unexpected errors.
        """
        results = []
        if not resp_list:
            return results

        for rid in resp_list:
            try:
                self.client.responses.delete(rid)
                self.logger.info(f"Response {rid} deleted from server")
                results.append(rid)

            except NotFoundError:
                self.logger.info(f"Response {rid} not found on server")
                results.append(rid)

            except Exception as e:
                try:
                    self.logger.error(f"Error deleting response {rid}: {e}")
                except Exception:
                    pass
                raise

        return results
    # End _delete_resp_from_list()


    def _delete_conv_from_list(self, conv_list: list[str]) -> list[str]:
        """
        Delete conversation objects from server.

        Returns a list of conversation IDs successfully handled.
        'Not found' is treated as success-equivalent/idempotent.
        Raises on unexpected errors.
        """
        results = []
        if not conv_list:
            return results

        for cid in conv_list:
            try:
                self.client.conversations.delete(cid)
                self.logger.info(f"Conversation {cid} deleted from server")
                results.append(cid)

            except NotFoundError:
                self.logger.info(f"Conversation {cid} not found on server")
                results.append(cid)

            except Exception as e:
                try:
                    self.logger.error(f"Error deleting conversation {cid}: {e}")
                except Exception:
                    pass
                raise

        return results
    # End _delete_conv_from_list()


    def _get_pending_cleanup_summary(self) -> dict:
        """
        Reconstruct cleanup state from the journal for debugging.

        Returns a dict with:
            requested: list of conversation IDs with cleanup_requested
            succeeded: list of conversation IDs with cleanup_succeeded
            pending: list of conversation IDs still pending cleanup
            response_counts: mapping of conv_id -> number of recorded response IDs
        """
        resp_ids_by_conv = {}
        requested = set()
        succeeded = set()

        for ev in self.journal.iter_events() or []:
            try:
                event = ev.get("event")
                conv_id = ev.get("conv_id")
                if not conv_id:
                    continue

                if event == "response_created":
                    resp_id = ev.get("resp_id")
                    if resp_id:
                        resp_ids_by_conv.setdefault(conv_id, set()).add(resp_id)

                elif event == "cleanup_requested":
                    requested.add(conv_id)

                elif event == "cleanup_succeeded":
                    succeeded.add(conv_id)

            except Exception as e:
                try:
                    self.logger.error(f"in _get_pending_cleanup_summary(): {e}")
                except Exception:
                    pass

        return {
            "requested": sorted(requested),
            "succeeded": sorted(succeeded),
            "pending": sorted(requested - succeeded),
            "response_counts": {
                conv_id: len(resp_ids)
                for conv_id, resp_ids in resp_ids_by_conv.items()
            },
        }
    # End _get_pending_cleanup_summary()


    def replay_pending_cleanups(self) -> None:
        """
        Replay any pending server-side cleanup operations recorded in the
        cleanup journal.

        A conversation is considered pending if:
        - cleanup_requested exists
        - cleanup_succeeded does not exist
        """
        if not self.delete_flag:
            try:
                self.logger.info("Skipping cleanup replay: DELETE_SERVER_SIDE disabled")
            except Exception:
                pass
            return

        resp_ids_by_conv = {}
        requested = set()
        succeeded = set()

        for ev in self.journal.iter_events() or []:
            try:
                event = ev.get("event")
                conv_id = ev.get("conv_id")
                if not conv_id:
                    continue

                if event == "response_created":
                    resp_id = ev.get("resp_id")
                    if resp_id:
                        resp_ids_by_conv.setdefault(conv_id, set()).add(resp_id)

                elif event == "cleanup_requested":
                    requested.add(conv_id)

                elif event == "cleanup_succeeded":
                    succeeded.add(conv_id)

            except Exception as e:
                try:
                    self.logger.error(f"in replay_pending_cleanups() parsing event: {e}")
                except Exception:
                    pass

        pending = sorted(requested - succeeded)

        if not pending:
            try:
                self.logger.info("No pending cleanup operations found in journal")
            except Exception:
                pass
            return

        try:
            self.logger.info(
                "Replaying pending cleanup for %d conversation(s)",
                len(pending)
            )
        except Exception:
            pass

        for conv_id in pending:
            resp_ids = sorted(resp_ids_by_conv.get(conv_id, set()))

            try:
                self.logger.info(
                    "Replaying cleanup for conversation %s with %d response id(s)",
                    conv_id, len(resp_ids)
                )
            except Exception:
                pass

            try:
                with self._inflight_lock:
                    self._delete_conversation(conv_id, resp_ids)

                self._journal_cleanup_succeeded(conv_id)

            except Exception as e:
                err = repr(e)

                try:
                    self.logger.error(
                        f"Replay cleanup failed for conversation {conv_id}: {e}"
                    )
                except Exception:
                    pass

                self._journal_cleanup_failed(conv_id, err)
    # End replay_pending_cleanups()


    def debug_log_cleanup_summary(self) -> None:
        """
        DEBUG-only helper to log reconstructed cleanup journal state.
        Intended for development/testing around replay_pending_cleanups().
        """
        try:
            if not self.logger.isEnabledFor(logging.DEBUG):
                return
        except Exception:
            return

        try:
            summary = self._get_pending_cleanup_summary()
            self.logger.debug("cleanup journal summary: %r", summary)
        except Exception as e:
            try:
                self.logger.debug(f"in debug_log_cleanup_summary()\n{e}")
            except Exception:
                pass


    def _delete_conversation(self, conv_id: str, resp_ids: list[str]) -> None:
        """
        Delete server-side artifacts for one conversation.
        """
        # Delete responses belonging to conversation
        self._delete_resp_from_list(resp_ids)
        # Delete conversation just ended, pass as list 
        self._delete_conv_from_list([conv_id])


    def end_conversation(self) -> None:
        """
        Cleanly end the current conversation client-side.

        If DELETE_SERVER_SIDE is enabled, perform server-side cleanup of:
        - responses created during this conversation
        - the conversation object itself

        Crash-safe journaling:
        - cleanup_requested is written before deletes
        - cleanup_succeeded or cleanup_failed is written after
        """
        # Snapshot and clear conversation state quickly under lock.
        with self._conversation_lock:
            conv_id = self.conversation_id
            self.conversation_id = None

        if not conv_id:
            return

        try:
            self.logger.info(f"Ending conversation {conv_id}")
        except Exception:
            pass

        if not self.delete_flag:
            return

        # Snapshot current response IDs outside the conversation lock.
        resp_ids = list(dict.fromkeys(self.session_resp_ids))

        # Persist intent before any server-side deletion begins.
        self._journal_cleanup_requested(conv_id)

        try:
            # Serialize cleanup against any in-flight request activity.
            with self._inflight_lock:
                self._delete_conversation(conv_id, resp_ids)

            # Only clear in-memory response IDs after successful cleanup.
            self.session_resp_ids.clear()

            self._journal_cleanup_succeeded(conv_id)

        except Exception as e:
            err = repr(e)

            try:
                self.logger.error(f"Cleanup failed for conversation {conv_id}: {e}")
            except Exception:
                pass

            self._journal_cleanup_failed(conv_id, err)

            # Re-raise so caller/UI can decide how noisy to be.
            raise
    # End end_conversation()


    def new_conversation(self) -> None:
        """
        Alias to preserve local API
        """
        self.end_conversation()


    def send_query(self, messages, lf=None, images_dir=None,
                   artifacts_dir=None, display_images=True) -> QueryResult:
        """
        Sends a query to the OpenAI Responses API.
        - messages: str or list of message dicts (see OpenAI docs)
        - lf: open file handle for logging (optional but recommended)
        - images_dir: directory to save images (required for image output)
        - artifacts_dir: directory to save container artifacts/files
        - display_images: if True, try to display images with `feh`
        Returns: QueryResult
        """

        start = time.time()

        # small retry loop for conversation_locked
        max_retries = 3
        backoff = 1.0  # seconds

        try:
            resp = None
            # serialize all requests per API instance (prevents self-inflicted conversation_locked)
            with self._inflight_lock:
                # Ensure we have a conversation (explicit model)
                self.logger.debug("in send_query(), calling _ensure_conversation()")
                self._ensure_conversation()

                for attempt in range(1, max_retries + 1):
                    # Snapshot conversation id (do not hold lock during network I/O)
                    with self._conversation_lock:
                        conversation_id = self.conversation_id

                    try:
                        self.logger.debug(
                            "in send_query(), about to create responses object (attempt %d/%d conv=%s)",
                            attempt, max_retries, conversation_id
                        )

                        resp = self.client.responses.create(
                            model=self.gpt_model,
                            input=self._build_prompt(messages),
                            tools=[{"type": "image_generation", "partial_images": 0},
                                   {"type": "web_search"},
                                   {"type": "file_search",
                                    "vector_store_ids": [self.vector_store_id]
                                   },
                                   {"type": "code_interpreter",
                                    "container": {"type": "auto", "memory_limit": "4g"}
                                   } 
                            ],
                            conversation=conversation_id,
                            # Note: if store=False, the model does not maintain conversation context
                            store=True,
                        )

                        self.logger.debug("in send_query(), response sent and returned")
                        self.logger.debug("resp.tools=%r", getattr(resp, "tools", None))
                        break

                    except openai.APIStatusError as e:
                        msg = str(e)
                        cond1 = "conversation_locked"
                        cond2 = "Another process is currently operating on this conversation"
                        if cond1 in msg or cond2 in msg:
                            self.logger.warning(
                                "conversation_locked for conversation %s (attempt %d/%d); retrying in %.1fs",
                                conversation_id, attempt, max_retries, backoff
                            )
                            if attempt == max_retries:
                                raise
                            time.sleep(backoff)
                            continue
                        raise
            # end inflight lock/retry loop

            if resp is None:
                # Fail right away
                raise RuntimeError("responses.create() failed without returning a response")

            # Add response.id to session list
            self.response_id = resp.id
            self.session_resp_ids.append(self.response_id)
            self._journal_response_created(conversation_id, self.response_id)

            # Sanity debug logging
            try:
                self.logger.debug(f"resp.store={resp.store} \
                                  resp.id={self.response_id} conv={self.conversation_id}")
            except Exception:
                pass

            # Debug-log response output items, especially tool usage
            try:
                self._log_response_output(resp)
            except Exception as e:
                try:
                    self.logger.debug(f"in send_query() calling _log_response_output()\n{e}")
                except Exception:
                    pass

            # Get our text output from the model's response
            text = resp.output_text or ""

            # Extract and save generated images
            image_paths = self._extract_and_save_images(resp, images_dir)

            # Download generated container artifacts
            artifact_paths = self._download_container_artifacts(resp, artifacts_dir)

            if lf and image_paths:
                for img in image_paths:
                    lf.write(f"[image] {img}\n")

            if lf and artifact_paths:
                for art in artifact_paths:
                    lf.write(f"[artifact] {art}\n")

            if lf and (image_paths or artifact_paths):
                lf.flush()

            # Display images, if any
            if display_images and image_paths:
                for img in image_paths:
                    try:
                        # Use 'feh' if present
                        proc.Popen(['feh', img])
                    except OSError:
                        # Try to fall back on ImageMagick
                        proc.Popen(['display', img])
                    except Exception as e:
                        self.logger.error(f"[system] Unable to display image: {e}")

            # Display container artifact images, if any
            if display_images and artifact_paths:
                for art in artifact_paths:
                    if Path(art).suffix.lower() == ".png":
                        try:
                            # Use 'feh' if present
                            proc.Popen(['feh', art])
                        except OSError:
                            # Try to fall back on ImageMagick
                            proc.Popen(['display', art])
                        except Exception as e:
                            self.logger.error(f"[system] Unable to display image: {e}")

            try:
                elapsed = time.time() - start
                self.logger.info(
                    f"run completed elapsed={elapsed:.2f}s resp_items={len(resp.output)}"
                )
            except Exception as e:
                print(f"in send_query()\n{e}")

            return QueryResult(
                text=text,
                image_paths=image_paths,
                artifact_paths=artifact_paths,
            )

        # Log errros and notify
        except openai.APIConnectionError as e:
            try:
                self.logger.error(f"APIConnectionError: {e}")
            except Exception as er:
                print(f"in send_query()\n{er}\n{e}")
            return QueryResult(
                    text="API Error: The server could not be reached. Check log."
            )

        except openai.RateLimitError as e:
            try:
                self.logger.error(f"RateLimitError: {e}")
            except Exception as er:
                print(f"in send_query()\n{er}\n{e}")
            return QueryResult(
                    text="API Error: A 429 status code was received; we should back off a bit."
            )

        except openai.APIStatusError as e:
            try:
                self.logger.error(f"APIStatusError: {e}")
            except Exception as er:
                print(f"in send_query()\n{er}\n{e}")
            return QueryResult(
                    text=f"API Error: A non-200-range status code was received\n {e}"
            )

        except Exception as e:
            try:
                self.logger.exception(f"Unexpected error during run: {e}")
            except Exception as er:
                print(f"in send_query()\n{er}\n{e}")
            return QueryResult(
                    text="API Error: An unexpected error occurred while streaming. Check log."
            )
        #finally:
        #    self.logger.debug("resp keys: %s", resp.model_dump().keys())
        #    self.logger.debug("resp: %s", resp.model_dump())
    # End send_query()


    # Upload file to OpenAI account
    def file_upload(self, filename: str) -> VectorStoreFileBatch:
        """
        Uploads a file.
        """
        if not os.path.isfile(filename) or os.path.getsize(filename) == 0:
            try:
                self.logger.info(f"upload skipped: empty or missing file {filename}")
            except Exception as e:
                print(f"in file_upload()\n{e}")
            return VectorStoreFileBatch(id="",
                                        created_at=0,
                                        file_counts={'cancelled': 1,
                                                     'completed': 0,
                                                     'failed': 0,
                                                     'in_progress': 0,
                                                     'total': 0},
                                        object="vector_store.files_batch",
                                        vector_store_id="",
                                        status="cancelled")

        file_streams = []
        try:
            file_streams.append(open(filename, "rb"))
            try:
                self.logger.debug(f"uploading 1 file to vector_store_id={self.vector_store.id}")
            except Exception as e:
                print(f"in file_upload()\n{e}")
            file_batch = self.client.vector_stores.file_batches.upload_and_poll(
                vector_store_id=self.vector_store.id, files=file_streams
            )
            try:
                self.logger.info(f"upload status={file_batch.status} file_counts={file_batch.file_counts}")
            except Exception as e:
                print(f"in file_upload()\n{e}")
            return file_batch
        except openai.APIConnectionError as e:
            try:
                self.logger.error(f"APIConnectionError during upload: {e}")
            except Exception as e:
                print(f"in file_upload()\n{e}")
            return VectorStoreFileBatch(id="",
                                        created_at=0,
                                        file_counts={'cancelled': 0,
                                                     'completed': 0,
                                                     'failed': 1,
                                                     'in_progress': 0,
                                                     'total': 0},
                                        object="vector_store.files_batch",
                                        vector_store_id="",
                                        status="failed")
        except openai.RateLimitError as e:
            try:
                self.logger.error(f"RateLimitError during upload: {e}")
            except Exception as er:
                print(f"in file_upload()\n{er}\n{e}")
            return VectorStoreFileBatch(id="",
                                        created_at=0,
                                        file_counts={'cancelled': 0,
                                                     'completed': 0,
                                                     'failed': 1,
                                                     'in_progress': 0,
                                                     'total': 0},
                                        object="vector_store.files_batch",
                                        vector_store_id="",
                                        status="failed")
        except openai.APIStatusError as e:
            try:
                self.logger.error(f"APIStatusError during upload: {e}")
            except Exception as er:
                print(f"in file_upload()\n{er}\n{e}")
            return VectorStoreFileBatch(id="",
                                        created_at=0,
                                        file_counts={'cancelled': 0,
                                                     'completed': 0,
                                                     'failed': 1,
                                                     'in_progress': 0,
                                                     'total': 0},
                                        object="vector_store.files_batch",
                                        vector_store_id="",
                                        status="failed")
        except Exception as e:
            try:
                self.logger.error(f"Unexpected error during upload: {e}")
            except Exception as er:
                print(f"in file_upload()\n{er}\n{e}")
            return VectorStoreFileBatch(id="",
                                        created_at=0,
                                        file_counts={'cancelled': 0,
                                                     'completed': 0,
                                                     'failed': 1,
                                                     'in_progress': 0,
                                                     'total': 0},
                                        object="vector_store.files_batch",
                                        vector_store_id="",
                                        status="failed")
        finally:
            for fs in file_streams:
                try:
                    fs.close()
                except Exception as e:
                    self.logger.debug(f"in file_upload()\n{e}")
    # End file_upload()
