    def _format_generated_files_notification(
        self,
        image_paths: list[str],
        artifact_paths: list[str],
    ) -> str:
        """
        Format a persistent in-chat notification listing generated files.
        """
        parts = []

        if image_paths:
            lines = ["Generated images:"]
            lines.extend(f"- `{path}`" for path in image_paths)
            parts.append("\n".join(lines))

        if artifact_paths:
            lines = ["Generated artifacts:"]
            lines.extend(f"- `{path}`" for path in artifact_paths)
            parts.append("\n".join(lines))

        return "\n\n".join(parts)


    async def on_mount(self) -> None:
