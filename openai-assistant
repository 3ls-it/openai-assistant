    def __init__(self, config, config_dir, chats_dir,
                 images_dir, artifacts_dir, journal_path, api_logger, *args, **kwargs
    ) -> None:
        super().__init__(*args, **kwargs)
        self.config = config
        self.config_dir = config_dir
        self.chats_dir = chats_dir
        self.images_dir = images_dir
        self.artifacts_dir = artifacts_dir
        self.journal_path = journal_path

        self.assistant_name = self.config["ASSISTANT_NAME"]
        self.user_name = self.config["YOUR_NAME"]

        # Create API instance
        self.api_logger = api_logger
        self.api = Openai_API(self.config, logger=self.api_logger, journal_path=self.journal_path)
        self.api.replay_pending_cleanups()
        #  Call the cleanup summary diagnostic if needed.
        #self.api.debug_log_cleanup_summary()
        try:
            self.api_logger.info("config: model="+str(self.config.get('MODEL'))+ \
