    @on(events.Key)
    async def on_key(self, event: events.Key) -> None:
        """
        The keystroke ctrl+backslash submits user input to the API,
        then displays returned result.
        """
        if event.key == "ctrl+backslash":
            if self.startup_screen:
                await self.chat_view.remove_children()
                self.startup_screen = False
            await self.show_status("")
            text = self.input_area._on_submit()
            if not text:
                return
            try:
                if self.lf:
                    self.lf.write("\n[user] "+text+"\n\n")
            except Exception as e:
                self.notify(f"[red]Error writing user input to log: {e}",
                            title="Write Error!",
                            severity="error",
                            timeout=5)

            self.input_area.load_text("Thinking...")
            await self.show_status("Sending query")
            await self.chat_view.mount(
                DisplayPrompt(text, border_title=self.user_name))

            start = time.time()
            self.api.logger.debug(f"calling send_query() at {start}")
            result = await asyncio.to_thread(
                self.api.send_query,
                text,
                self.lf,
                self.images_dir,
                self.artifacts_dir,
            )
            elapsed = time.time() - start

            has_text = bool(result.text and result.text.strip())
            if has_text:
                try:
                    if self.lf:
                        self.lf.write("\n[assistant] " + result.text + "\n\n")
                        self.lf.flush()
                except Exception as e:
                    self.notify(
                        f"[red]Error writing AI response to log: {e}",
                        title="Error Saving File!",
                        severity="error",
                        timeout=5,
                    )

                if "API Error" in result.text:
                    await self.chat_view.mount(
                        DisplayNotifications(result.text, border_title=self.assistant_name)
                    )
                else:
                    await self.chat_view.mount(
                        DisplayResponse(result.text, border_title=self.assistant_name)
                    )

            if result.image_paths or result.artifact_paths:
                note = self._format_generated_files_notification(
                    result.image_paths,
                    result.artifact_paths,
                )
                await self.chat_view.mount(
                    DisplayNotifications(note, border_title="Notification")
                )

            self.input_area.clear()
            await self.show_status(f"Run completed in {elapsed:.2f}s")
