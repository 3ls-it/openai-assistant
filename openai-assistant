    def compose(self) -> ComposeResult:
        if self.status == "cancelled":
            msg = f"[yellow]Upload of {self.path}[/] cancelled"
        elif self.status == "completed":
            msg = f"[green]Uploaded {self.path}[/]"
        elif self.status == "failed":
